{
  "manifest_version": 3,
  "name": "FpbxCTC",
  "version": "1.0",
  "description": "FreePBX Click-to-Call — right-click any selected phone number to dial via your PBX.",

  "permissions": ["contextMenus", "storage", "notifications"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "FpbxCTC Settings",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
